--- a/mt76_connac.h
+++ b/mt76_connac.h
@@ -176,3 +176,8 @@ static inline bool is_mt7925(struct mt76_dev *dev)
 {
-	return mt76_chip(dev) == 0x7925;
+	return mt76_chip(dev) == 0x7925 || mt76_chip(dev) == 0x7927;
